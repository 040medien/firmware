#!/bin/sh
# Early debug ssh: start dropbear at the very top of rcS so the board stays
# reachable even if a later init script stalls. eth0 is already up from the
# kernel ip= cmdline, and /etc is writable via the overlay set up by /init,
# so dropbear -R can generate host keys here.
case "$1" in
	start)
		echo "Starting early dropbear (debug) on :22 ..."
		mkdir -p /etc/dropbear
		dropbear -R -p 22
		;;
	stop)
		;;
	*)
		echo "Usage: $0 {start|stop}"
		exit 1
		;;
esac
